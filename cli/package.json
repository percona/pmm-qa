{
  "name": "pmm-cli-tests",
  "version": "1.0.0",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/percona/pmm-qa.git"
  },
  "scripts": {
    "lint": "npm run lint:ts && npm run typecheck && echo 'Lint OK'",
    "lint:ts": "eslint .",
    "lint:ts:fix": "eslint --fix .",
    "typecheck": "tsc --noEmit",
    "report": "playwright show-report",
    "cli:help": "npx playwright test --grep @help",
    "cli:server-only": "npx playwright test --grep @server-only",
    "cli:client-docker": "npx playwright test --grep @client-docker",
    "cli:generic": "npx playwright test --grep \"@generic|@unregister\"",
    "cli:remove": "npx playwright test --grep @service-removal",
    "cli:ps": "npx playwright test --grep @ps",
    "cli:mysql": "npx playwright test --grep @mysql",
    "cli:mysql-conf": "npx playwright test --grep @mysql-conf-file",
    "cli:pgsql": "npx playwright test --grep @pdpgsql",
    "cli:psmdb": "npx playwright test --grep @psmdb",
    "cli:psmdb-shard": "npx playwright test --grep @shard-psmdb",
    "cli:haproxy": "npx playwright test --grep @haproxy",
    "cli:proxysql": "npx playwright test --grep @proxysql",
    "cli:mongo": "npx playwright test --grep @mongoDb",
    "cli:all": "npx playwright test"
  },
  "dependencies": {
    "@faker-js/faker": "^8.4.1",
    "@playwright/test": "^1.61.1",
    "@types/luxon": "^3.7.2",
    "adm-zip": "^0.6.0",
    "luxon": "^3.7.2",
    "playwright": "^1.61.1",
    "playwright-core": "^1.61.1",
    "prettier": "^3.9.5",
    "shelljs": "^0.10.0",
    "typescript": "^5.9.3",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^20.19.0",
    "@types/shelljs": "^0.10.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "dotenv": "^16.6.1",
    "eslint": "^8.57.1",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-playwright": "^0.18.0"
  },
  "overrides": {
    "brace-expansion@1": "1.1.16"
  }
}
