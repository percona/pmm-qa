# Copy to .env for local Playwright runs. Staging values are common for manual QA.
# Migration runs use run-migration-single-test.sh, which exports PMM_UI_URL=http://127.0.0.1/
# and PMM_MIGRATION=1 so shell env wins over this file (see playwright.config.ts).
PMM_UI_URL=http://127.0.0.1/
ADMIN_PASSWORD=admin-password
WORKERS=1
